generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
}

model Category {
  id              String           @id @default(uuid())
  name            String
  sellingType     String           @default("unit")
  packageSizes    String?
  products        Product[]
  displaySections DisplaySection[]
  flavors         Flavor[]
}

model Flavor {
  id         String    @id @default(uuid())
  name       String
  imageUrl   String?
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Product {
  id            String     @id @default(uuid())
  name          String
  description   String
  price         Float
  packagePrices String?
  gramsPrices   String?
  gramsOptions  String?
  imageUrls     String?
  discount      Float?
  minFlavors    Int        @default(0)
  maxFlavors    Int        @default(0)
  imageUrl      String
  active        Boolean    @default(true)
  categories    Category[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt
}

model DisplaySection {
  id           String    @id @default(uuid())
  title        String
  type         String
  active       Boolean   @default(true)
  categoryId   String?
  productIds   String?
  order        Int
  startDate    DateTime?
  endDate      DateTime?
  tags         String?
  gramsOptions String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("display_sections")
}
